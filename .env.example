# Configuration RTE API
RTE_CLIENT_ID=your_client_id_here
RTE_CLIENT_SECRET=your_client_secret_here

# Configuration ENTSO-E API (prix spot électricité)
# Inscription gratuite sur : https://transparency.entsoe.eu/usrm/user/createPublicUser
ENTSOE_API_KEY=your_entsoe_api_key_here

# Configuration base de données
# Valeurs possibles: sqlite, postgresql
DATABASE_TYPE=sqlite

# Configuration PostgreSQL (si DATABASE_TYPE=postgresql)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rte_consommation
POSTGRES_USER=rte_user
POSTGRES_PASSWORD=rte_secure_password

# Configuration API
LOG_LEVEL=INFO
